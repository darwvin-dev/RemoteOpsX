{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RemoteOpsX",
  "version": "0.1.0",
  "identifier": "dev.remoteopsx.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "RemoteOpsX",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm"],
    "category": "Network",
    "shortDescription": "Unified Linux remote operations workspace",
    "longDescription": "RemoteOpsX is a Linux-first remote operations desktop app: SSH/SFTP/RDP/VNC access, live agentless server health monitoring, service & Docker diagnostics, logs, tunnels and executable runbooks.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": ["openssh-client"]
      }
    }
  }
}
